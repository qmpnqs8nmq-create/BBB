    classDef gatewayLayer fill:#3a3a3a,stroke:#000,color:#fff
    classDef chiefLayer fill:#fff2cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef specialistStrat fill:#dae8fc,stroke:#6c8ebf,color:#000
    classDef specialistMarket fill:#d5e8d4,stroke:#82b366,color:#000
    classDef specialistExec fill:#ffe6cc,stroke:#d79b00,color:#000
    classDef specialistCoach fill:#e1d5e7,stroke:#9673a6,color:#000
